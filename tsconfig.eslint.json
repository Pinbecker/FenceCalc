{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@fence-estimator/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@fence-estimator/geometry": [
        "packages/geometry/src/index.ts"
      ],
      "@fence-estimator/rules-engine": [
        "packages/rules-engine/src/index.ts"
      ]
    },
    "types": [
      "node",
      "vite/client"
    ]
  },
  "include": [
    "apps/api/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "packages/contracts/src/**/*.ts",
    "packages/geometry/src/**/*.ts",
    "packages/rules-engine/src/**/*.ts"
  ]
}
