{
  "name": "@fence-estimator/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8",
    "migrate": "node scripts/migrate.mjs",
    "backup:sqlite": "node scripts/backup-sqlite.mjs",
    "restore:sqlite": "node scripts/restore-sqlite.mjs",
    "recover:user": "node scripts/reset-user-password.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fence-estimator/contracts": "0.1.0",
    "@fence-estimator/rules-engine": "0.1.0",
    "@sentry/node": "^10.46.0",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
