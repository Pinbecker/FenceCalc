{
  "name": "@fence-estimator/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8",
    "backup:sqlite": "node scripts/backup-sqlite.mjs",
    "restore:sqlite": "node scripts/restore-sqlite.mjs",
    "recover:user": "node scripts/reset-user-password.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fence-estimator/contracts": "0.1.0",
    "@fence-estimator/rules-engine": "0.1.0",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
