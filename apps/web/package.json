{
  "name": "@fence-estimator/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-single-port.mjs",
    "build": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && vite build",
    "typecheck": "tsc -p tsconfig.typecheck.json && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage.enabled --coverage.provider=v8",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fence-estimator/contracts": "0.1.0",
    "@fence-estimator/geometry": "0.1.0",
    "@fence-estimator/rules-engine": "0.1.0",
    "konva": "^9.3.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.5"
  },
  "devDependencies": {
    "@sentry/react": "^10.46.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "vite": "^8.0.3"
  }
}
