# API runtime
NODE_ENV=development
HOST=127.0.0.1
PORT=3001
TRUST_PROXY=false
DATABASE_PATH=./apps/api/data/fence-estimator.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
BODY_LIMIT_BYTES=262144
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX_REQUESTS=120
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MS=900000
AUDIT_LOG_RETENTION_DAYS=365
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SESSION_TTL_DAYS=30
SESSION_COOKIE_NAME=fence_estimator_session
SESSION_COOKIE_SECURE=false
BOOTSTRAP_OWNER_SECRET=
LOG_LEVEL=info

# Web runtime
VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Optional build-time sourcemap upload for the web app
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
