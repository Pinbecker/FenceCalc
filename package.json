{
  "name": "fence-estimator",
  "private": true,
  "version": "0.1.0",
  "description": "Production-grade 2D fence layout and estimation platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "npm run dev --workspace @fence-estimator/web",
    "dev:api": "npm run dev --workspace @fence-estimator/api",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "turbo": "^2.4.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.8"
  }
}

