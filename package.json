{
  "name": "fence-estimator",
  "private": true,
  "version": "0.1.0",
  "description": "Production-grade 2D fence layout and estimation platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "npm run dev --workspace @fence-estimator/web",
    "dev:api": "node scripts/kill-port.mjs 3001 && npm --prefix packages/contracts run build && npm --prefix packages/geometry run build && npm --prefix packages/rules-engine run build && npm --prefix apps/api run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.exclude=**/dist/** --coverage.exclude=**/*.d.ts --coverage.exclude=**/index.ts --coverage.exclude=**/App.tsx --coverage.exclude=**/AdminPage.tsx --coverage.exclude=**/DashboardPage.tsx --coverage.exclude=**/DrawingsPage.tsx --coverage.exclude=**/EditorPage.tsx --coverage.exclude=**/LoginPage.tsx --coverage.exclude=**/main.tsx --coverage.exclude=**/server.ts --coverage.exclude=**/vite.config.ts --coverage.exclude=**/scripts/** --coverage.exclude=**/usePortalSession.ts --coverage.exclude=**/useWorkspacePersistence.ts --coverage.exclude=**/WorkspacePanel.tsx --coverage.thresholds.lines=70 --coverage.thresholds.functions=70 --coverage.thresholds.statements=70 --coverage.thresholds.branches=60",
    "test:e2e": "node scripts/run-e2e.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "tsx": "^4.19.3",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.8"
  }
}
